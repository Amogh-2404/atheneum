# This project's server links a NATIVE module (better-sqlite3) hard-bound to the Node
# ABI. The launchd server runs Node 22 (/usr/local/bin); a wrong-node `npm install`
# silently rebuilds the addon for the wrong ABI and crash-loops prod. engine-strict
# makes a mismatched install FAIL LOUD instead. To install under the right node:
# `PATH=/usr/local/bin:$PATH npm install ...`, or run `npm run db:rebuild`.
engine-strict=true
legacy-peer-deps=true
